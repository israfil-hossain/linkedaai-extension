{
  "manifest_version": 3,
  "name": "Outlye",
  "version": "1.2.0",
  "description": "Generate personalized LinkedIn outreach messages using AI",
  "homepage_url": "https://outlye.flowtim.com",
  "permissions": [
    "activeTab",
    "storage",
    "identity",
    "sidePanel",
    "scripting"
  ],
  "host_permissions": [
    "https://www.linkedin.com/*",
    "https://linkedin.com/*",
    "https://outlye.flowtim.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/*", "https://linkedin.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "popup/popup.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["popup/*"],
      "matches": ["https://www.linkedin.com/*"]
    }
  ]
}